<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Meridian Residence</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Three.js CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <!-- React and ReactDOM CDNs -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@0.344.0/dist/umd/lucide.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;0,600;1,500&family=Inter:wght@400;500;600;700&display=swap');
        .font-serif { font-family: 'Fraunces', serif; }
        body { font-family: 'Inter', sans-serif; margin: 0; overflow: hidden; user-select: none; background-color: #0b1220; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes pulseMarker { 0%, 100% { box-shadow: 0 0 0 0 rgba(201,169,97,0.55); } 50% { box-shadow: 0 0 0 10px rgba(201,169,97,0); } }
        .animate-fadeUp { animation: fadeUp .45s ease forwards; }
        .animate-fadeIn { animation: fadeIn .3s ease forwards; }
        .marker-pulse { animation: pulseMarker 2.4s ease-in-out infinite; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script>
        // Injecting the complete working React code directly into the document
        const { useState, useEffect, useRef, useCallback } = React;
        
        // Setup Lucide icons locally from window element
        const Sofa = (p) => React.createElement('span', null, '🛋️');
        const Waves = (p) => React.createElement('span', null, '🌊');
        const BedDouble = (p) => React.createElement('span', null, '🛏️');
        const ChefHat = (p) => React.createElement('span', null, '🍳');
        const Flame = (p) => React.createElement('span', null, '🔥');
        const X = () => React.createElement('span', null, '✕');
        const Sun = () => React.createElement('span', null, '☀️');
        const Moon = () => React.createElement('span', null, '🌙');
        const RotateCcw = () => React.createElement('span', null, '🔄');
        const Ruler = () => React.createElement('span', null, '📐');
        const MapPin = () => React.createElement('span', null, '📍');
        const MessageCircle = () => React.createElement('span', null, '💬');
        const Send = () => React.createElement('span', null, '➔');
        const ArrowLeft = () => React.createElement('span', null, '←');
        const Sparkles = () => React.createElement('span', null, '✨');
        const Loader2 = () => React.createElement('span', null, '⌛');
        const Calendar = () => React.createElement('span', null, '📅');
        const Check = () => React.createElement('span', null, '✓');
        const Menu = () => React.createElement('span', null, '☰');
        const Phone = () => React.createElement('span', null, '📞');
        const Mail = () => React.createElement('span', null, '✉️');

        const HOTSPOTS = [
          { id: "living", icon: Sofa, label: "The Great Room", floor: "ground", room: "Great Room", stat: "1,420 sf", tags: ["Glass walls", "Oak flooring"], desc: "Motorized glass walls slide fully open onto the terrace.", pos: [2, 1.9, 4.6], camPos: [11, 6, 15], camTarget: [2, 2, 3.5] },
          { id: "pool", icon: Waves, label: "The Horizon Pool", floor: "ground", room: "Horizon Pool", stat: "1,800 sf deck", tags: ["Vanishing edge", "Heated"], desc: "A sixty-foot vanishing edge blurs into the coastline.", pos: [-6, 0.5, 8], camPos: [-3, 4.5, 17], camTarget: [-6, 0.3, 8] },
          { id: "master", icon: BedDouble, label: "The Owner's Suite", floor: "upper", room: "Owner's Suite", stat: "960 sf", tags: ["Private terrace", "Soaking tub"], desc: "Set on its own upper wing, opening onto a private terrace.", pos: [-1.5, 4.9, 2.05], camPos: [-9, 7.5, 11], camTarget: [-1.5, 4.7, 1.5] },
          { id: "kitchen", icon: ChefHat, label: "The Culinary Studio", floor: "ground", room: "Culinary Studio", stat: "640 sf", tags: ["Marble island", "Gaggenau suite"], desc: "A twelve-foot bookmatched marble island built for entertaining.", pos: [-6.4, 1.9, -1], camPos: [-14, 6, 3], camTarget: [-6.4, 1.9, -1] },
          { id: "skylounge", icon: Flame, label: "The Rooftop Lounge", floor: "upper", room: "Rooftop Lounge", stat: "1,100 sf", tags: ["270° views", "Sunken fire lounge"], desc: "A sunken fire lounge turns the rooftop into a third living room.", pos: [-1.5, 6.7, -1], camPos: [6, 10, -11], camTarget: [-1.5, 6.5, -1] }
        ];

        const FLOORS = {
          ground: { label: "Ground Floor", rooms: [{ name: "Foyer", hotspot: null, x: 1, y: 1, w: 1, h: 1 }, { name: "Great Room", hotspot: "living", x: 2, y: 1, w: 2, h: 1 }, { name: "Dining", hotspot: null, x: 4, y: 1, w: 1, h: 1 }, { name: "Culinary Studio", hotspot: "kitchen", x: 1, y: 2, w: 2, h: 1 }, { name: "Guest Suite", hotspot: null, x: 4, y: 2, w: 1, h: 1 }, { name: "Horizon Pool", hotspot: "pool", x: 1, y: 3, w: 4, h: 1 }] },
          upper: { label: "Upper Floor", rooms: [{ name: "Owner's Suite", hotspot: "master", x: 1, y: 1, w: 2, h: 1 }, { name: "Bedroom Two", hotspot: null, x: 3, y: 1, w: 1, h: 1 }, { name: "Bedroom Three", hotspot: null, x: 4, y: 1, w: 1, h: 1 }, { name: "Study", hotspot: null, x: 1, y: 2, w: 1, h: 1 }, { name: "Rooftop Lounge", hotspot: "skylounge", x: 2, y: 2, w: 3, h: 1 }] }
        };

        const DEFAULT_CAM_POS = [20, 13, 24];
        const DEFAULT_CAM_TARGET = [0, 3, 0];

        function createOrbitControls(camera, domElement) {
          const controls = { target: new THREE.Vector3(), enabled: true, minDistance: 1, maxDistance: Infinity, maxPolarAngle: Math.PI - 0.05, minPolarAngle: 0.05 };
          const spherical = new THREE.Spherical(), sphericalDelta = new THREE.Spherical(), offset = new THREE.Vector3(), panOffset = new THREE.Vector3();
          let scale = 1, isRotating = false, isPanning = false;
          const rotateStart = new THREE.Vector2(), rotateEnd = new THREE.Vector2(), rotateDelta = new THREE.Vector2(), panStart = new THREE.Vector2();

          function pan(deltaX, deltaY) {
            const distance = camera.position.distanceTo(controls.target);
            const fovRad = (camera.fov * Math.PI) / 180;
            const targetHeight = 2 * Math.tan(fovRad / 2) * distance;
            const panX = new THREE.Vector3().setFromMatrixColumn(camera.matrix, 0).multiplyScalar((-deltaX * targetHeight) / domElement.clientHeight);
            const panY = new THREE.Vector3().setFromMatrixColumn(camera.matrix, 1).multiplyScalar((deltaY * targetHeight) / domElement.clientHeight);
            panOffset.add(panX).add(panY);
          }
          function onPointerDown(e) { if (!controls.enabled) return; if (e.button === 2 || e.button === 1) { isPanning = true; panStart.set(e.clientX, e.clientY); } else { isRotating = true; rotateStart.set(e.clientX, e.clientY); } }
          function onPointerMove(e) { if (!controls.enabled) return; if (isRotating) { rotateEnd.set(e.clientX, e.clientY); rotateDelta.subVectors(rotateEnd, rotateStart).multiplyScalar((2 * Math.PI) / domElement.clientHeight); sphericalDelta.theta -= rotateDelta.x; sphericalDelta.phi -= rotateDelta.y; rotateStart.copy(rotateEnd); } else if (isPanning) { const panEnd = new THREE.Vector2(e.clientX, e.clientY); pan(panEnd.x - panStart.x, panEnd.y - panStart.y); panStart.copy(panEnd); } }
          function onPointerUp() { isRotating = false; isPanning = false; }
          domElement.addEventListener("pointerdown", onPointerDown); domElement.addEventListener("pointermove", onPointerMove); window.addEventListener("pointerup", onPointerUp);
          
          controls.update = function () {
            offset.copy(camera.position).sub(controls.target); spherical.setFromVector3(offset);
            spherical.theta += sphericalDelta.theta; spherical.phi += sphericalDelta.phi;
            spherical.phi = Math.max(controls.minPolarAngle, Math.min(controls.maxPolarAngle, spherical.phi));
            spherical.makeSafe(); spherical.radius *= scale;
            controls.target.add(panOffset); offset.setFromSpherical(spherical);
            camera.position.copy(controls.target).add(offset); camera.lookAt(controls.target);
            sphericalDelta.theta *= 0.9; sphericalDelta.phi *= 0.9; scale = 1; panOffset.set(0, 0, 0);
          };
          controls.dispose = () => { domElement.removeEventListener("pointerdown", onPointerDown); domElement.removeEventListener("pointermove", onPointerMove); window.removeEventListener("pointerup", onPointerUp); };
          return controls;
        }

        function buildVilla(scene) {
          const refs = { windowMats: [], glowMats: [], pointLights: [], rings: [], night: {} };
          const matStone = new THREE.MeshStandardMaterial({ color: 0xece3d0, roughness: 0.9 });
          const matSlate = new THREE.MeshStandardMaterial({ color: 0x2b3240, roughness: 0.7 });
          const matGold = new THREE.MeshStandardMaterial({ color: 0xc9a961, metalness: 0.8, roughness: 0.2 });
          const matGrass = new THREE.MeshStandardMaterial({ color: 0x5f7a4c, roughness: 1 });
          const matWater = new THREE.MeshStandardMaterial({ color: 0x2f7f96, roughness: 0.1, transparent: true, opacity: 0.8 });

          const ground = new THREE.Mesh(new THREE.PlaneGeometry(100, 100), matGrass);
          ground.rotation.x = -Math.PI/2; scene.add(ground);

          const base = new THREE.Mesh(new THREE.BoxGeometry(16, 3.5, 10), matStone);
          base.position.set(0, 1.75, 0); scene.add(base);

          const roof = new THREE.Mesh(new THREE.BoxGeometry(17, 0.4, 11), matSlate);
          roof.position.set(0, 3.7, 0); scene.add(roof);

          const pool = new THREE.Mesh(new THREE.PlaneGeometry(8, 12), matWater);
          pool.rotation.x = -Math.PI/2; pool.position.set(-6, 0.05, 8); scene.add(pool);

          HOTSPOTS.forEach((hs) => {
            const r = new THREE.Mesh(new THREE.RingGeometry(0.2, 0.3, 16), new THREE.MeshBasicMaterial({ color: 0xc9a961, side: THREE.DoubleSide }));
            r.position.set(...hs.pos); r.rotation.x = -Math.PI/2; scene.add(r); refs.rings.push(r);
          });
          return refs;
        }

        function App() {
          const mountRef = useRef(null);
          const [activeHotspot, setActiveHotspot] = useState(null);
          const [activeFloor, setActiveFloor] = useState("ground");
          const [ready, setReady] = useState(false);

          useEffect(() => {
            const scene = new THREE.Scene(); scene.background = new THREE.Color(0xcfe4ee);
            const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(...DEFAULT_CAM_POS);
            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            mountRef.current.appendChild(renderer.domElement);

            const controls = createOrbitControls(camera, renderer.domElement);
            const sun = new THREE.DirectionalLight(0xffffff, 1.2); sun.position.set(10, 20, 10); scene.add(sun);
            scene.add(new THREE.AmbientLight(0xffffff, 0.6));

            const refs = buildVilla(scene);
            setReady(true);

            function run() { requestAnimationFrame(run); controls.update(); renderer.render(scene, camera); }
            run();
            return () => { controls.dispose(); renderer.dispose(); };
          }, []);

          return React.createElement('div', { className: 'relative w-screen h-screen overflow-hidden' },
            React.createElement('div', { ref: mountRef, className: 'absolute inset-0' }),
            React.createElement('div', { className: 'absolute top-6 left-6 text-white z-20 bg-slate-900/80 p-6 rounded-2xl border border-white/15 backdrop-blur' },
                React.createElement('h1', { className: 'font-serif text-2xl text-[#E4CC8E]' }, 'The Meridian'),
                React.createElement('p', { className: 'text-xs text-white/60 tracking-widest uppercase mt-1' }, 'Malibu Architectural Tour')
            )
          );
        }

        ReactDOM.render(React.createElement(App), document.getElementById('root'));
    </script>
</body>
</html>
